# Copy this file to ".env" and fill in real values locally.
# ".env" itself is git-ignored and must never be committed.
#
# These variables are referenced from testdata/*.json files using the
# "${VAR_NAME}" placeholder syntax and are resolved automatically by
# utilities/json_reader_utility.py at test-data load time.

STANDARD_USER_PASSWORD=
LOCKED_OUT_USER_PASSWORD=
INVALID_USER_PASSWORD=

TEST_CARD_NUMBER=
TEST_CARD_EXPIRY=
TEST_CARD_CVV=
